MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database>"

NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# Same origin as the app when using custom server (default). Override if Socket.IO runs elsewhere.
# NEXT_PUBLIC_SOCKET_URL="http://localhost:3000"

# Production CORS for Socket.IO browser origins (optional; dev allows all)
# NEXT_PUBLIC_APP_ORIGIN="https://your-app.example"

# After Nginx + Certbot serve HTTPS on 443, point these at https:// and rebuild:
# NEXT_PUBLIC_API_URL="https://your-host.example/api"
# Optional: if Nginx still proxies plain HTTP to Node, set "true" to 301-redirect to https://
# FORCE_HTTPS_REDIRECT="true"

JWT_SECRET="secret55"

JWT_EXPIRES="7d"
# or (no both)
# JWT_COOKIE_MAX_AGE_SEC=604800